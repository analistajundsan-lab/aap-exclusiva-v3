# ============================================================
# AAP Exclusiva v3.0 - Environment Variables
# ============================================================
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# ----- Database -----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aap_db
# Para SQLite (desenvolvimento local sem Docker):
# DATABASE_URL=sqlite:///./dev.db

# ----- JWT -----
JWT_SECRET_KEY=sua-chave-secreta-muito-segura-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- Aplicação -----
ENVIRONMENT=development
# production | development | test

# ----- Grafana -----
GRAFANA_PASSWORD=admin
